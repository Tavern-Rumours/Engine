{% macro render(node, page, ancestors = []) %}

    {% set isRoot = node.url == "/" %}
    {% set isActive = node.url == page.url %}
    {% set isOpen = isRoot or ancestors.has(node.url) %}

    <div class="nav-node">

        {% if node.children.length and not isRoot %}
            <button class="toggle" data-open="{{ isOpen }}">
                {{ "-" if isOpen else "+" }}
            </button>
        {% else %}
            <span class="spacer"></span>
        {% endif %}

        <a  href="{{ node.url | url }}"
            class="{{ "active" if isActive else "" }}">
            {{ node.name }}
        </a>

        {% if node.children.length %}
            <div class="children"
                style="display: {{ "block" if isOpen else "none" }}">
                {% for child in node.children %}
                    {{ render(child, page, ancestors) }}
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endmacro %}
