<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta property="og:site-name" content="" />
        <meta name="author" content="" />
        <title>{{title or displayTitle}}</title>
        <meta property="og:title" content="{{title or displayTitle}}" />
        <meta name="description" content="{{description}}" />
        <meta property="og:description" content="{{description}}" />
        <meta property="og:image" content="{{headerImage}}" />
        <meta property="og:image:secure-url" content="{{headerImage}}" />

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap-grid.min.css" rel="stylesheet" />

        <link rel="stylesheet" href="{{ '/_styles/main.css' | url }}" />

        <!-- Add your FontAwesome script here -->
        
    </head>
    <body>
        {%- set navigation = collections.navGraph -%}
        {%- set ancestors = navigation | getAncestors(page.filePathStem) -%}
        
        {%- from "partials/sidebar-nav.njk" import render -%}
        <div class="sidebar-nav">
            <script src="/_scripts/menuToggle.js"></script>
            <div class="navigation">
                <script src="/_scripts/navToggle.js"></script>
                {{ render(navigation.root, page, ancestors) }}
            </div>
        </div>

        <div class="content">
            {%- include "partials/header.njk" -%}
            <button id="menu-toggle"><i class="fa-solid fa-bars" id="menu-toggle"></i></button>
            <main class="page">
                {%- if title %}<h1>{{ title }}</h1>{% endif -%}
                {%- include "partials/sidebar.njk" -%}
                {{ content | safe }}
            </main>

            {%- include "partials/tooltip.njk" -%}
            {%- include "partials/copyrightFooter.njk" -%}
            <script src="/_scripts/secretToggle.js"></script>
        </div>
    </body>
</html>
